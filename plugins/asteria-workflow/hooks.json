{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Asteria/plugins/asteria-workflow/scripts/asteria_codex_hook.ps1 -Event SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Asteria/plugins/asteria-workflow/scripts/asteria_codex_hook.ps1 -Event UserPromptSubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "shell_command|apply_patch|codebase_retrieval|sequentialthinking|automation_update",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Asteria/plugins/asteria-workflow/scripts/asteria_codex_hook.ps1 -Event PreToolUse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "shell_command|apply_patch|codebase_retrieval|sequentialthinking|automation_update",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Asteria/plugins/asteria-workflow/scripts/asteria_codex_hook.ps1 -Event PostToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Asteria/plugins/asteria-workflow/scripts/asteria_codex_hook.ps1 -Event Stop"
          }
        ]
      }
    ]
  }
}
